# MoneyMate backend (same host the web app's NEXT_PUBLIC_BASE_URL points at).
# Production:
EXPO_PUBLIC_BASE_URL=https://moneymate-backend-tau.vercel.app/api/v1
# Local backend from a real device/simulator — use your machine's LAN IP, NOT localhost:
# EXPO_PUBLIC_BASE_URL=http://192.168.1.50:8000/api/v1

# Native Google Sign-In (@react-native-google-signin/google-signin) — requires a custom dev build (NOT Expo Go).
# "Web client" OAuth client ID from the Google Cloud console — needed to receive an idToken the backend can verify.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# "iOS client" OAuth client ID (iOS only). The reversed form also goes in app.json's iosUrlScheme.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
